<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>نظام تخطيط الإنتاج والمشتريات - سوفي باك</title>
    <style>
        :root { --primary: #2c3e50; --secondary: #34495e; --accent: #3498db; --danger: #e74c3c; --warning: #f1c40f; --success: #27ae60; }
        body { font-family: 'Segoe UI', Arial, sans-serif; background: #f4f7f9; margin: 0; padding: 20px; color: var(--primary); }
        .container { max-width: 1400px; margin: auto; }
        .machine-card { background: white; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); margin-bottom: 30px; overflow: hidden; border-top: 5px solid var(--accent); }
        .machine-header { background: #f8f9fa; padding: 15px 20px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #eee; }
        .machine-title { font-size: 1.2rem; font-weight: bold; color: var(--primary); }
        .capacity-input { display: flex; align-items: center; gap: 10px; }
        
        table { width: 100%; border-collapse: collapse; background: white; }
        th { background: var(--secondary); color: white; padding: 12px; font-size: 0.85rem; position: sticky; top: 0; }
        td { border: 1px solid #eee; padding: 8px; text-align: center; }
        
        input { border: 1px solid #ddd; padding: 6px; border-radius: 4px; text-align: center; width: 80px; }
        input[type="date"] { width: 120px; }
        
        .alert-low { background-color: #ffdada !important; color: #c0392b; font-weight: bold; } /* نفاذ قريب */
        .alert-warning { background-color: #fff4d1 !important; } /* حد الطلب */
        
        .badge { padding: 4px 8px; border-radius: 12px; font-size: 0.75rem; font-weight: bold; }
        .status-ok { background: var(--success); color: white; }
        .status-buy { background: var(--danger); color: white; }

        .summary-bar { background: var(--primary); color: white; padding: 15px; border-radius: 8px; margin-bottom: 20px; display: flex; gap: 20px; }
        .btn-action { background: var(--accent); color: white; border: none; padding: 10px 20px; border-radius: 5px; cursor: pointer; font-weight: bold; }
        .btn-action:hover { background: #2980b9; }
    </style>
</head>
<body>

<div class="container">
    <div class="summary-bar">
        <span>📦 نظام الرقابة على المخزون</span>
        <span>|</span>
        <span>اليوم: 29 أبريل 2026</span>
    </div>

    <div id="machinesContainer"></div>

    <button class="btn-action" onclick="calculateAll()">🔄 تحديث جميع الحسابات والمؤشرات</button>
</div>

<script>
    // قاعدة بيانات الماكينات والخامات
    const machines = [
        { name: "ماكينة أفلام البولى بروبلين PP", cap: 480, mats: ["HOMO", "CO Polymer", "AS", "AB", "SLIP", "MB white"] },
        { name: "ماكينة أفلام PE", cap: 240, mats: ["LLDPE M1", "LLDPE M2", "LDPE 0.75", "LDPE 2", "Metallocene", "AS", "AB", "SLIP", "PR", "MB White"] },
        { name: "ماكينة غطاء CSD", cap: 150, mats: ["HDPE", "Color MB"] },
        { name: "ماكينة غطاء WD", cap: 88, mats: ["HDPE", "Color MB"] },
        { name: "ماكينة سحب شيت PP", cap: 180, mats: ["Homo", "تكسير PP", "تلك", "Color MB"] },
        { name: "ماكينة سحب شيت PET", cap: 200, mats: ["PET", "فلاكس", "تكسير"] }
    ];

    function init() {
        const container = document.getElementById('machinesContainer');
        machines.forEach((m, mIdx) => {
            let html = `
                <div class="machine-card" id="machine-${mIdx}">
                    <div class="machine-header">
                        <div class="machine-title">${m.name}</div>
                        <div class="capacity-input">
                            طاقة شهرية: <input type="number" class="m-cap" value="${m.cap}" onchange="calculateAll()"> طن
                            | يومي: <span class="m-daily-val">0</span> طن
                        </div>
                    </div>
                    <table>
                        <thead>
                            <tr>
                                <th>الخامة</th>
                                <th>النسبة %</th>
                                <th>طلب يومي</th>
                                <th>المخزون</th>
                                <th>كفاية (يوم)</th>
                                <th>حد الأمان</th>
                                <th>تعاقد (بري/بحري)</th>
                                <th>التغطية النهائية</th>
                                <th>القرار</th>
                            </tr>
                        </thead>
                        <tbody>`;
            
            m.mats.forEach((mat, matIdx) => {
                html += `
                    <tr class="mat-row">
                        <td><strong>${mat}</strong></td>
                        <td><input type="number" class="ratio" value="0"></td>
                        <td class="daily-req">0</td>
                        <td><input type="number" class="stock" value="0"></td>
                        <td class="stock-days">0</td>
                        <td><input type="number" class="safety" value="5" title="أيام"></td>
                        <td>
                            <input type="number" class="incoming" placeholder="كمية">
                        </td>
                        <td class="final-date date-cell">-</td>
                        <td class="decision">-</td>
                    </tr>`;
            });

            html += `</tbody></table></div>`;
            container.innerHTML += html;
        });
        calculateAll();
    }

    function calculateAll() {
        const cards = document.querySelectorAll('.machine-card');
        const today = new Date();

        cards.forEach(card => {
            const monthlyCap = parseFloat(card.querySelector('.m-cap').value) || 0;
            const dailyCap = monthlyCap / 30;
            card.querySelector('.m-daily-val').innerText = dailyCap.toFixed(2);

            const rows = card.querySelectorAll('.mat-row');
            rows.forEach(row => {
                const ratio = parseFloat(row.querySelector('.ratio').value) / 100 || 0;
                const stock = parseFloat(row.querySelector('.stock').value) || 0;
                const safetyDays = parseFloat(row.querySelector('.safety').value) || 0;
                const incoming = parseFloat(row.querySelector('.incoming').value) || 0;

                const dailyNeed = dailyCap * ratio;
                row.querySelector('.daily-req').innerText = dailyNeed.toFixed(3);

                if (dailyNeed > 0) {
                    const daysStock = stock / dailyNeed;
                    const finalDays = (stock + incoming) / dailyNeed;
                    
                    row.querySelector('.stock-days').innerText = Math.floor(daysStock);
                    row.querySelector('.final-date').innerText = formatDate(today, finalDays);

                    // منطق التنبيهات والقرار
                    const decisionCell = row.querySelector('.decision');
                    const stockDaysCell = row.querySelector('.stock-days');

                    if (daysStock <= safetyDays) {
                        row.classList.add('alert-low');
                        decisionCell.innerHTML = `<span class="badge status-buy">شراء فوري</span>`;
                    } else if (daysStock <= (safetyDays + 3)) {
                        row.classList.remove('alert-low');
                        row.classList.add('alert-warning');
                        decisionCell.innerHTML = `<span class="badge" style="background:#f39c12; color:white;">تحت المراقبة</span>`;
                    } else {
                        row.classList.remove('alert-low', 'alert-warning');
                        decisionCell.innerHTML = `<span class="badge status-ok">آمن</span>`;
                    }
                }
            });
        });
    }

    function formatDate(date, days) {
        if (!days || days <= 0) return "-";
        let d = new Date(date);
        d.setDate(d.getDate() + Math.floor(days));
        return d.toLocaleDateString('ar-EG');
    }

    window.onload = init;
</script>

</body>
</html>
